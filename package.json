{
  "name": "daily-entry-app",
  "version": "1.0.0",
  "description": "APD",
  "author": "MK makarkarma21@gmail.com",
  "private": true,
  "homepage": "./",
  "license": "MIT",
  "main": "electron.js",
  "dependencies": {
    "@capacitor/android": "^8.3.0",
    "@capacitor/cli": "^8.3.0",
    "@capacitor/core": "^8.3.0",
    "@electron/remote": "^2.1.3",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^13.5.0",
    "chart.js": "^4.4.9",
    "date-fns": "^3.6.0",
    "leaflet": "^1.9.4",
    "qrcode.react": "^4.2.0",
    "react": "^18.2.0",
    "react-beautiful-dnd": "^13.1.1",
    "react-chartjs-2": "^5.3.0",
    "react-dom": "^18.2.0",
    "react-leaflet": "^4.2.0",
    "react-scripts": "5.0.1",
    "sass": "^1.87.0",
    "web-vitals": "^5.1.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "electron": "^28.1.0",
    "electron-builder": "^24.6.4",
    "electron-reload": "^2.0.0-alpha.1",
    "gh-pages": "^6.3.0",
    "wait-on": "^7.2.0"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "predeploy": "npm run build",
    "build:gp": "PUBLIC_URL=/apd/ react-scripts build",
    "build:vercel": "CI=false PUBLIC_URL=/ react-scripts build",
    "deploy": "gh-pages -d build",
    "vercel-build": "npm run build:vercel",
    "electron:dev": "concurrently -k \"npm start\" \"wait-on http://localhost:3000 && electron .\"",
    "electron:build": "npm run build && electron-builder",
    "electron:pack": "npm run build && electron-builder --dir"
  },
  "build": {
    "appId": "com.yourname.dailyentry",
    "productName": "APD |Analytic Personal Dashboard|",
    "directories": {
      "output": "dist"
    },
    "files": [
      "build/**/*",
      "electron.js"
    ],
    "extraResources": [
      {
        "from": "public",
        "to": "public",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "public/logo256.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "eslintConfig": {
    "extends": [
      "react-app"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
